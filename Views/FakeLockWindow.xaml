<Window x:Class="rdpManager.Views.FakeLockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保活防窥锁屏" WindowStyle="None" WindowState="Maximized" Topmost="True" 
        ShowInTaskbar="False" Background="Black" Cursor="Arrow"
        WindowStartupLocation="Manual">

    <Grid x:Name="MainGrid">
        <!-- 仅在主屏幕的锁屏窗口上显示的内容 -->
        <StackPanel x:Name="LockContentPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
            
            <!-- 大时钟 -->
            <TextBlock x:Name="TxtTime" Text="12:00:00" FontSize="72" FontWeight="Thin" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <!-- 日期 -->
            <TextBlock x:Name="TxtDate" Text="2026年6月23日 星期二" FontSize="18" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,48"/>
            
            <!-- 提示信息 -->
            <TextBlock Text="🔒 系统已进入保活防窥锁屏状态" FontSize="14" Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,0,0,24"/>
            
            <!-- 密码输入区 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <PasswordBox x:Name="TxtUnlockPassword" PasswordChar="*" Width="240" Height="36" Padding="8,6" VerticalContentAlignment="Center" FontSize="16" KeyDown="TxtUnlockPassword_KeyDown">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Setter Property="Background" Value="#1A1A1A"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="BorderBrush" Value="#333333"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Style.Resources>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>
                <Button Content="解锁" Width="80" Height="36" Margin="10,0,0,0" Click="BtnUnlock_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FFFFFF"/>
                            <Setter Property="Foreground" Value="#000000"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" x:Name="border">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#EAEAEA"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            
            <!-- 错误提示 -->
            <TextBlock x:Name="TxtError" Text="密码错误，请重新输入" FontSize="12" Foreground="#FF3366" HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
